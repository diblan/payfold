{
  "priority": 3,
  "request": {
    "method": "POST",
    "urlPath": "/psp/charges",
    "bodyPatterns": [
      {
        "matchesJsonPath": {
          "expression": "$.subscription_id",
          "matches": "^.*e$"
        }
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": { "status": "succeeded" },
    "fixedDelayMilliseconds": 3000
  }
}
